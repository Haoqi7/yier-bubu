{
  "name": "yier-bubu",
  "version": "1.0.0",
  "description": "一二布布 - 桌面宠物软件",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "author": "一二与布布工作室",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.yieryububu.desktop-pet",
    "productName": "一二与布布",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.png",
      "identity": null
    },
    "files": [
      "main.js",
      "preload.js",
      "config.js",
      "index.html",
      "settings.html",
      "help.html",
      "draw.html",
      "renderer/**/*",
      "assets/**/*"
    ]
  },
  "dependencies": {
    "gif-encoder-2": "^1.0.5",
    "gifwrap": "^0.10.1"
  }
}
