{
  "name": "yi-er-yu-bu-bu",
  "version": "1.0.0",
  "description": "一二与布布 - 桌面宠物软件",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "prebuild:win": "powershell -ExecutionPolicy Bypass -File download-vc-redist.ps1"
  },
  "author": "一二与布布工作室",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.yieryububu.desktop-pet",
    "productName": "一二与布布",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "build/vc_redist.x64.exe",
        "to": "vc_redist.x64.exe"
      },
      {
        "from": "build/vc_redist.x86.exe",
        "to": "vc_redist.x86.exe"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "一二与布布",
      "include": "build/installer.nsh"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.png",
      "identity": null
    },
    "files": [
      "main.js",
      "preload.js",
      "config.js",
      "index.html",
      "settings.html",
      "help.html",
      "draw.html",
      "renderer/**/*",
      "assets/**/*"
    ]
  },
  "dependencies": {
    "gif-encoder-2": "^1.0.5",
    "gifwrap": "^0.10.1"
  }
}